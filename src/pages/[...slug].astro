---
import Layout from '../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages
    .filter((p: CollectionEntry<'pages'>) => p.data.template === 'default')
    .map((p: CollectionEntry<'pages'>) => ({
      params: { slug: p.id },
      props: { page: p },
    }));
}

const { page } = Astro.props as { page: CollectionEntry<'pages'> };
const { Content } = await render(page);
const { heading, subheading, title, description } = page.data;

const isAbout = page.id === 'om-os';
const isContact = page.id === 'kontakt';

const employees = isAbout
  ? (await getCollection('employees')).sort(
      (a: CollectionEntry<'employees'>, b: CollectionEntry<'employees'>) => a.data.order - b.data.order
    )
  : [];
---

<Layout title={title} description={description}>

  <section class="max-w-6xl mx-auto px-6 py-20">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight">{heading}</h1>
    {subheading && <p class="mt-4 text-lg text-gray-500 max-w-2xl">{subheading}</p>}
  </section>

  <!-- Markdown body (om-os har indhold, kontakt har ikke) -->
  <div class="max-w-3xl mx-auto px-6 pb-8 prose prose-gray">
    <Content />
  </div>

  <!-- Om os: værdier + medarbejdere -->
  {isAbout && (
    <>
      <section class="bg-gray-50 py-20">
        <div class="max-w-6xl mx-auto px-6">
          <h2 class="text-2xl font-bold mb-10">Hvad vi tror på</h2>
          <div class="grid md:grid-cols-3 gap-8">
            <div>
              <h3 class="font-semibold text-lg mb-2">Enkelhed</h3>
              <p class="text-gray-500 text-sm">God design er usynlig. Vi fjerner støj og sætter det vigtigste i centrum.</p>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-2">Samarbejde</h3>
              <p class="text-gray-500 text-sm">Vi ser os selv som en forlængelse af dit team – ikke bare en leverandør.</p>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-2">Kvalitet</h3>
              <p class="text-gray-500 text-sm">Vi leverer ikke halvfærdige løsninger. Hvert projekt får den opmærksomhed det fortjener.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="max-w-6xl mx-auto px-6 py-20">
        <h2 class="text-2xl font-bold mb-10">Mød teamet</h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">
          {employees.map((emp: CollectionEntry<'employees'>) => (
            <div class="border border-gray-200 rounded-2xl p-6">
              <div class="w-16 h-16 rounded-full bg-gray-100 mb-4 overflow-hidden">
                {emp.data.image
                  ? <img src={emp.data.image} alt={emp.data.name} class="w-full h-full object-cover" />
                  : <div class="w-full h-full flex items-center justify-center text-2xl font-bold text-gray-300">
                      {emp.data.name.charAt(0)}
                    </div>
                }
              </div>
              <h3 class="font-semibold text-lg">{emp.data.name}</h3>
              <p class="text-sm text-gray-400">{emp.data.role}</p>
              {emp.data.bio && <p class="mt-3 text-sm text-gray-500">{emp.data.bio}</p>}
              {emp.data.email && (
                <a href={`mailto:${emp.data.email}`} class="mt-3 inline-block text-sm text-gray-400 hover:text-gray-700 transition-colors">
                  {emp.data.email}
                </a>
              )}
            </div>
          ))}
        </div>
      </section>
    </>
  )}

  <!-- Kontakt: info + formular -->
  {isContact && (
    <section class="max-w-6xl mx-auto px-6 pb-24">
      <div class="grid md:grid-cols-2 gap-16">
        <div class="space-y-4 text-sm text-gray-500">
          <div>
            <p class="font-medium text-gray-900">Email</p>
            <a href="mailto:hej@vizuall.dk" class="hover:text-gray-900 transition-colors">hej@vizuall.dk</a>
          </div>
          <div>
            <p class="font-medium text-gray-900">Telefon</p>
            <a href="tel:+4500000000" class="hover:text-gray-900 transition-colors">+45 00 00 00 00</a>
          </div>
          <div>
            <p class="font-medium text-gray-900">Adresse</p>
            <p>København, Danmark</p>
          </div>
        </div>

        <form class="space-y-6" name="kontakt" method="POST">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Navn</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-gray-400 transition-colors"
              placeholder="Dit navn"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-gray-400 transition-colors"
              placeholder="din@email.dk"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Besked</label>
            <textarea
              id="message"
              name="message"
              required
              rows={5}
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-gray-400 transition-colors resize-none"
              placeholder="Fortæl os om dit projekt..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-black text-white py-3 rounded-full text-sm font-medium hover:bg-gray-800 transition-colors"
          >
            Send besked
          </button>
        </form>
      </div>
    </section>
  )}

</Layout>
