---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Vizuall – kreativt bureau' } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Forside' },
  { href: '/cases', label: 'Cases' },
  { href: '/om-os', label: 'Om os' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} – Vizuall</title>
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">

    <header class="border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
        <a href="/" class="font-bold text-xl tracking-tight">Vizuall</a>
        <nav class="flex gap-6 text-sm">
          {nav.map(({ href, label }) => (
            <a
              href={href}
              class={`transition-colors hover:text-black ${
                currentPath === href ? 'text-black font-medium' : 'text-gray-500'
              }`}
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-gray-100 mt-24">
      <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-400">
        <p>© {new Date().getFullYear()} Vizuall. Alle rettigheder forbeholdes.</p>
        <nav class="flex gap-6">
          {nav.map(({ href, label }) => (
            <a href={href} class="hover:text-gray-700 transition-colors">{label}</a>
          ))}
        </nav>
      </div>
    </footer>

  </body>
</html>
